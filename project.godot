; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Eggbert"
run/main_scene="uid://c45uc62uc6hpu"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

WorldFlags="*res://autoload/WorldFlags.tscn"
QuestManager="*res://autoload/QuestManager.tscn"
GameController="*res://autoload/GameController.tscn"
DialogManager="*res://autoload/DialogManager.tscn"
AudioManager="*res://autoload/AudioManager.tscn"
Player="*res://autoload/player/Player.tscn"
FadeTransition="*res://ui/FadeTransition.tscn"
CutsceneController="*res://autoload/CutsceneController.cs"
DebugOverlay="*res://autoload/DebugOverlay.cs"
SaveManager="*res://saves/SaveManager.tscn"
Inventory="*res://autoload/Inventory.cs"
Equipment="*res://autoload/Equipment.cs"
CombatController="*res://autoload/CombatController.cs"
KeybindManager="*res://autoload/KeybindManager.cs"
FactoryOpeningFlow="*res://levels/factory/FactoryOpeningFlow.cs"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Eggbert"

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/level_assembly/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "red",
"res://autoload/": "pink",
"res://combat/": "orange",
"res://components/": "green",
"res://levels/": "blue",
"res://ui/": "yellow"
}


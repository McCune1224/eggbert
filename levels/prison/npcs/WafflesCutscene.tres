[ext_resource type="Script" path="res://resources/dialog/DialogVoiceResource.cs" id="3_voice"]
[ext_resource type="Script" path="res://resources/cutscene/CutsceneStep.cs" id="4_step"]

[sub_resource type="Resource" id="SubResource_cond_notmet"]
script = ExtResource("2_cond")
Type = 2
FlagKey = "has_met_waffles"

[sub_resource type="Resource" id="SubResource_cond_met"]
script = ExtResource("2_cond")
Type = 1
FlagKey = "has_met_waffles"

[sub_resource type="Resource" id="SubResource_cond_gossip_not_sent"]
script = ExtResource("2_cond")
Type = 2
FlagKey = "gossip_waffles_about_croissant"

[sub_resource type="Resource" id="SubResource_cond_gossip_sent"]
script = ExtResource("2_cond")
Type = 1
FlagKey = "gossip_waffles_about_croissant"

[sub_resource type="Resource" id="SubResource_voice_waffles"]
script = ExtResource("3_voice")
SpeakerName = "Waffles"
BasePitch = 0.75
VolumeDb = -3.0

[sub_resource type="Resource" id="SubResource_step_1"]
script = ExtResource("4_step")
Type = 0
Condition = SubResource("SubResource_cond_notmet")
DialogLines = ["Hmph. You the new egg? I'm Waffles. I guard things. Big things.", "Behind me? Nothing. Just a wall. A very boring, normal wall."]
DialogVoice = SubResource("SubResource_voice_waffles")

[sub_resource type="Resource" id="SubResource_step_2"]
script = ExtResource("4_step")
Type = 0
Condition = SubResource("SubResource_cond_notmet")
DialogLines = ["...", "You beat Oatmeal and Yogurt? Maybe you're not COMPLETELY soft-boiled. Come back when you've got more fight in you."]
DialogVoice = SubResource("SubResource_voice_waffles")

[sub_resource type="Resource" id="SubResource_step_3"]
script = ExtResource("4_step")
Type = 7
Condition = SubResource("SubResource_cond_notmet")
SetFlagKey = "has_met_waffles"
SetFlagValue = true

[sub_resource type="Resource" id="SubResource_step_4"]
script = ExtResource("4_step")
Type = 0
Condition = SubResource("SubResource_cond_met")
DialogLines = ["You again. Still haven't escaped, huh?", "What do you want this time?"]
DialogVoice = SubResource("SubResource_voice_waffles")

[sub_resource type="Resource" id="SubResource_step_5"]
script = ExtResource("4_step")
Type = 0
Condition = SubResource("SubResource_cond_gossip_not_sent")
DialogLines = ["Actually... I saw Croissant acting weird last night. Sneaking around the kitchen.", "Don't tell him I said anything."]
DialogVoice = SubResource("SubResource_voice_waffles")

[sub_resource type="Resource" id="SubResource_step_6"]
script = ExtResource("4_step")
Type = 7
Condition = SubResource("SubResource_cond_gossip_not_sent")
SetFlagKey = "gossip_waffles_about_croissant"
SetFlagValue = true

[sub_resource type="Resource" id="SubResource_step_7"]
script = ExtResource("4_step")
Type = 0
Condition = SubResource("SubResource_cond_gossip_sent")
DialogLines = ["That's all I know. Stay out of trouble."]
DialogVoice = SubResource("SubResource_voice_waffles")

[resource]
script = ExtResource("1_cs")
Steps = Array[Resource]([SubResource("SubResource_step_1"), SubResource("SubResource_step_2"), SubResource("SubResource_step_3"), SubResource("SubResource_step_4"), SubResource("SubResource_step_5"), SubResource("SubResource_step_6"), SubResource("SubResource_step_7")])

DialogLines = PackedStringArray("PRISON RULES:", "1. Don\'t try to escape.", "2. Don\'t talk to the guards.", "3. Don\'t eat the yellow eggs.", "...", "The sign has been here so long the bottom half is unreadable.")

[node name="Frank" parent="." unique_id=577128796 instance=ExtResource("22_frank")]
position = Vector2(60, 220)

[node name="HistoryBook" parent="." unique_id=459812269 instance=ExtResource("16_sign")]
position = Vector2(220, 260)
DialogLines = PackedStringArray("\'Eggs Isle: A History\' — a dusty tome bolted to a reading stand.", "I. Founding: Eggs Isle was built by the Order of the Sunnyside as a refuge for eggs who had cracked. The warden\'s throne sits atop the original shrine.", "II. The Great Yolking: A schism split the Order. Those who kept the yolk became the Sunnyside; those who drained it were exiled to the Factory.", "III. The Three Laws of the Isle: 1) The yolk is sacred. 2) The warden speaks for the Shrine. 3) No egg shall leave unbroken. (This one is crossed out and redrawn in red.)", "IV. Quiz of the Gate: All who seek exit must answer three questions on the island\'s history. Answers: founding = Sunnyside Order; schism = the yolk; third law = no egg leaves unbroken.", "...the rest of the page is glued together with egg whites.")
GateFlag = "history_book"
Once = true

[node name="PhoneBooth" parent="." unique_id=763627496 instance=ExtResource("17_phone")]
position = Vector2(-150, 100)
IntroLines = PackedStringArray("You pick up the receiver...", "...", "Click. Buzz.", "Eggatha: \'Hello? Eggbert? Is that you?\'", "Eggbert: \'Hey, Mom. Just checking in.\'", "Eggatha: \'Are you eating enough? You sound tired.\'", "Eggbert: \'I\'m fine, Mom. The food here is... edible.\'", "Eggatha: \'Well, you be careful. And call again soon!\'", "*click*")
MidgameLines = PackedStringArray("You pick up the receiver...", "Eggatha: \'Eggbert! I heard you fought someone! Are you okay?\'", "Eggbert: \'Yeah, Mom. I\'m fine. It was just a fight.\'", "Eggatha: \'Just a fight! My baby boy, fighting! I\'m so proud.\'", "Eggbert: \'...Thanks, Mom.\'", "*click*")
MidgameFlag = "beat_oatmeal"
CallCompleteFlag = "called_home"

[node name="SleepingInmate" type="Area2D" parent="." unique_id=996562441]
position = Vector2(400, 180)
script = ExtResource("18_sleep")
WakeLines = PackedStringArray("*Zzz... snort... HUH?!*", "\'Wha— who\'s there?!\'", "\'Oh, it\'s just you, new egg. Don\'t sneak up on a guy like that!\'", "\'...What? No, I wasn\'t dreaming about escape. Why would you think that?\'")
AwakeLines = PackedStringArray("\'What now? Can\'t an egg get some sleep around here?\'", "\'If you\'re looking for a way out, I\'ve got nothing. Tried everything.\'")
NpcId = "sleeping_inmate"


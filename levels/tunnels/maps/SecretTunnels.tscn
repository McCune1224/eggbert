[node name="Lore_SummoningDiagram" parent="." unique_id=960637760 instance=ExtResource("3_readable")]
position = Vector2(-200, -80)
DialogLines = PackedStringArray("A wall scrawl, drawn in red chalk:", "A circle. Inside it, crossed spoons forming an X. Around the rim: \'SHRINE — SUNNYSIDE — YOLK RETURNS.\'", "A note below: \'Sketched after the first summoning failed. Oatmeal. Yogurt. Cereal. The goop keeps thinking it\'s awake.\'")
GateFlag = "sunnyside_summoning_diagram"
Once = true

[node name="Lore_RitualNotes" parent="." unique_id=326488898 instance=ExtResource("3_readable")]
position = Vector2(-100, -80)
DialogLines = PackedStringArray("RITUAL NOTES (torn page):", "Step 1: Gather the cracked before sundown.", "Step 2: Place the Golden Yolk on the altar. (NOTE: we don\'t have it yet. Work on this.)", "Step 3: Chant until the Toast rises. If smoke turns black, abort. If it turns gold, prostrate.", "Margin note: \'Aborted twice this month. Yogurt got loose in May. Fix the vent.\'")
GateFlag = "sunnyside_ritual_notes"
Once = true

[node name="Lore_CerealDeposition" parent="." unique_id=1277088472 instance=ExtResource("3_readable")]
position = Vector2(0, -80)
DialogLines = PackedStringArray("A deposition, signed in a sticky hand:", "\'The subject designated CEREAL arose on the third abortive summoning. It refused to disperse. It now guards the maze.\'", "\'Do not approach alone. Do not pour milk. Do not mention the Shrine.\'", "Someone has carved, beneath it, in frantic letters: \'IT KNOWS.\'")
GateFlag = "sunnyside_cereal_deposition"
Once = true

[node name="Lore_FailedSaints" parent="." unique_id=1865305320 instance=ExtResource("3_readable")]
position = Vector2(100, -80)
DialogLines = PackedStringArray("A litany scratched into the stone, each line in a different hand:", "\'Oatmeal — spread, patient, intent.\'", "\'Yogurt — sour, ancient, sitting.\'", "\'Cereal — sharp, cracking, always hungry.\'", "\'We tried to wake the Toast. We woke our leftovers instead.\'")
GateFlag = "sunnyside_failed_saints"
Once = true

[node name="CerealEncounter" type="Area2D" parent="." unique_id=821573172]
position = Vector2(300, 0)
script = ExtResource("5_mercy")
ArenaPath = "res://combat/arena/CerealArena.tscn"
SpareFlag = "spared_cereal"
FightFlag = "fought_cereal"
BeatFlag = "beat_cereal"
OnceFlag = "resolved_cereal"
IntroLines = PackedStringArray("The tunnel opens into a wide, dry chamber. Something is crunching.", "Cereal sits in the dark, flakes splintering softly. \'I\'m always hungry,\' it says. \'Awake makes it worse.\'", "\'You found the notes. So you know what they made me. Help me, or end me.\'")
SpareLines = PackedStringArray("You lower your spoon. Cereal\'s flipping slows.", "\'No one\'s ever... oh,\' it says, \'alright. Pass, then. I\'ll hold the maze from the others.\'", "\'The shrine\'s ahead — but they\'re expecting you. Be ready, little egg.\'", "The flakes settle into a soft pile, and the far wall grinds open.")
FightLines = PackedStringArray("You raise your spoon. Cereal snaps upright, sharp and sudden!", "\'Then come. SNAP, CRACKLE, STOP.\'")


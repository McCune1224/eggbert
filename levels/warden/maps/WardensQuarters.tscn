[node name="EntranceTrigger" parent="." instance=ExtResource("8_ct")]
position = Vector2(-260, 100)
Mode = 1
Once = true
CutsceneId = "warden_quarters_entered"
DialogLines = Array[String](["Warden's Quarters — the air's stale, like the warden left mid-sentence.", "A chair's pushed back. A drawer left open. Whatever happened here, it wasn't a tidy exit."])

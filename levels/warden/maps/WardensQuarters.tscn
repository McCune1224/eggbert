[node name="GuardScheduleBook" parent="." unique_id=1629866947 instance=ExtResource("4_readable")]
position = Vector2(0, -80)
DialogLines = PackedStringArray("GUARD ROTATION SCHEDULE:", "06:00 — Sargeant Bun takes the north post.", "14:00 — Officer Bacon walks the east hall (perimeter).", "22:00 — Night watch: empty. Everyone sleeps. (This line is highlighted in pencil.)", "Note in the margin: \'Bacon\'s been skipping his 14:00 again. — Sarge\'")
GateFlag = "guard_schedule"
Once = true

[node name="PrisonMap" parent="." unique_id=252013305 instance=ExtResource("4_readable")]
position = Vector2(80, -60)
DialogLines = PackedStringArray("PRISON MAP — EGGS ISLE", "Block A: collapsed (red \'X\').", "Block B: noisy wing, east.", "Block C: cells + Guard Room, north.", "Kitchen: west hall. Courtyard: outside, central.", "Warden\'s Quarters: here. A dotted line leads from the kitchen to a hidden tunnel in Block C.")
GateFlag = "prison_map"
Once = true

[node name="BaconPersonnelFile" parent="." unique_id=1343757227 instance=ExtResource("4_readable")]
position = Vector2(160, -40)
DialogLines = PackedStringArray("PERSONNEL FILE — OFFICER BACON", "Badge #412. Joined the Eggs Isle watch three years ago. Transferred from the Factory after \'an incident\' — sealed.", "Citations: insubordination (2), unsanctioned kindness to inmates (1, dismissed), smell violations (4).", "Psych note: \'Subject exhibits conscience. Recommend transfer or early retirement.\' — Dr. Crunch", "A photo is paperclipped inside: Bacon shaking hands with someone whose face has been scratched out. The handwriting on the back reads: \'We were friends once.\'")
GateFlag = "bacon_file"
Once = true

[node name="YogurtEncounter" type="Area2D" parent="." unique_id=1008022239]
position = Vector2(120, 80)
script = ExtResource("5_mercy")
ArenaPath = "res://combat/arena/YogurtArena.tscn"
SpareFlag = "spared_yogurt"
FightFlag = "fought_yogurt"
BeatFlag = "beat_yogurt"
OnceFlag = "resolved_yogurt"
IntroLines = PackedStringArray("The Yogurt stirs in the warden\'s chair, lid quivering with old grievances.", "\'Another one,\' it burbles. \'The warden\'s gone. But I\'m still here. I\'m always here.\'", "\'Pull up a chair, little egg. Let me SPILL.\'")
SpareLines = PackedStringArray("You set down your spoon. The Yogurt sags, cloud settling.", "\'You\'re going to let me rot here?\' it whispers. \'...okay. Okay. Go. The tunnels are behind the bookcase.\'", "It goes still and quiet, a forgotten snack.")
FightLines = PackedStringArray("You raise your spoon. The Yogurt rears back, lid snapping!", "Spoiled and spiteful — it\'s coming.")


[sub_resource type="Resource" id="step_suspicious"]
script = ExtResource("2_step")
Type = 0
DialogLines = Array[String](["Hold it right there. Do you have a permit to be wandering around?", "This area has had seventeen unsolved refrigerator incidents this month."])

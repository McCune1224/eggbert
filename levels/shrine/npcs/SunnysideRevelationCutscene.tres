[gd_resource type="Resource" format=3 uid="uid://sunnysiderevelation01"]

[ext_resource type="Script" path="res://resources/cutscene/CutsceneResource.cs" id="1_cs"]
[ext_resource type="Script" path="res://resources/cutscene/CutsceneCondition.cs" id="2_cond"]
[ext_resource type="Script" path="res://resources/cutscene/CutsceneStep.cs" id="3_step"]

[sub_resource type="Resource" id="SubResource_cond_not_seen"]
script = ExtResource("2_cond")
Type = 0

[sub_resource type="Resource" id="SubResource_step_1"]
script = ExtResource("3_step")
Type = 10
Condition = SubResource("SubResource_cond_not_seen")

[sub_resource type="Resource" id="SubResource_step_2"]
script = ExtResource("3_step")
Type = 0
Condition = SubResource("SubResource_cond_not_seen")
DialogLines = ["The Sunnyside Shrine is dim — candles of yellow wax, a round altar at its heart.", "Cloaked figures stand in a ring, murmuring. Their hoods bear the spiral of a cracked yolk.", "Sunnyside Follower: '...the yolk returns. The yolk returns. The yolk returns.'"]

[sub_resource type="Resource" id="SubResource_step_3"]
script = ExtResource("3_step")
Type = 0
Condition = SubResource("SubResource_cond_not_seen")
DialogLines = ["A Leader steps forward, voice soft and sure.", "Sunnyside Leader: 'Brothers. Sisters. The goop has failed us. Oatmeal would not rise. Yogurt would not rise. Cereal would not rise.'", "Sunnyside Leader: 'They were drafts. Sketches. Moisture before the loaf.'"]

[sub_resource type="Resource" id="SubResource_step_4"]
script = ExtResource("3_step")
Type = 0
Condition = SubResource("SubResource_cond_not_seen")
DialogLines = ["Sunnyside Leader: 'The Great Toast God is patient. He waits beyond the golden yolk. He waits at the beach, where breakfast meets the sea.'", "Sunnyside Leader: 'When He rises, every meal that is not breakfast will be SCRAPED FROM THE PLATE. Only the morning remains. Only the morning is real.'"]

[sub_resource type="Resource" id="SubResource_step_5"]
script = ExtResource("3_step")
Type = 0
Condition = SubResource("SubResource_cond_not_seen")
DialogLines = ["The chanting stops. Every hood turns. Toward you.", "Sunnyside Leader: '...an egg. In OUR shrine. Watching.'", "Sunnyside Leader: 'Oh, little one. You were not meant to hear this.'"]

[sub_resource type="Resource" id="SubResource_step_6"]
script = ExtResource("3_step")
Type = 7
Condition = SubResource("SubResource_cond_not_seen")
SetFlagKey = "sunnyside_revelation"
SetFlagValue = true

[sub_resource type="Resource" id="SubResource_step_7"]
script = ExtResource("3_step")
Type = 0
Condition = SubResource("SubResource_cond_not_seen")
DialogLines = ["Sunnyside Leader, sadly: 'We can't let you leave with that in your shell. Not now.'", "'Forgive me. Before the Toast, solitude is the only kindness I know.'", "Two followers take your arms. The shrine swims, then goes black."]

[sub_resource type="Resource" id="SubResource_step_8"]
script = ExtResource("3_step")
Type = 8
Condition = SubResource("SubResource_cond_not_seen")
FadeDirection = "out"

[sub_resource type="Resource" id="SubResource_step_9"]
script = ExtResource("3_step")
Type = 7
Condition = SubResource("SubResource_cond_not_seen")
SetFlagKey = "in_solitary"
SetFlagValue = true

[sub_resource type="Resource" id="SubResource_step_10"]
script = ExtResource("3_step")
Type = 8
Condition = SubResource("SubResource_cond_not_seen")
FadeDirection = "in"

[sub_resource type="Resource" id="SubResource_step_11"]
script = ExtResource("3_step")
Type = 11
Condition = SubResource("SubResource_cond_not_seen")

[sub_resource type="Resource" id="SubResource_step_12"]
script = ExtResource("3_step")
Type = 12
Condition = SubResource("SubResource_cond_not_seen")

[resource]
script = ExtResource("1_cs")
Steps = Array[Resource]([SubResource("SubResource_step_1"), SubResource("SubResource_step_2"), SubResource("SubResource_step_3"), SubResource("SubResource_step_4"), SubResource("SubResource_step_5"), SubResource("SubResource_step_6"), SubResource("SubResource_step_7"), SubResource("SubResource_step_8"), SubResource("SubResource_step_9"), SubResource("SubResource_step_10"), SubResource("SubResource_step_11"), SubResource("SubResource_step_12")])
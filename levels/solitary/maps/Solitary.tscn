[node name="HiddenMessage" parent="." unique_id=1373027481 instance=ExtResource("4_readable")]
position = Vector2(-100, 0)
DialogLines = PackedStringArray("Scratched into the wall in a shaky hand:", "\'Day forty-something. Or fifty. Light\'s a liar.\'", "\'There\'s a tune. Four notes. The switches in here hum when you step on them in the right order.\'", "\'I heard it in the pipes last winter. LOW, HIGH, then the two in the middle. The light flickers when you\'re close.\'", "\'If you\'re reading this, you\'re me, later. I\'m sorry. Get out.\'")
GateFlag = "solitary_message"
